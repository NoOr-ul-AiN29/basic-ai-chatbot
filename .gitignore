# .gitignore — Files Git should NOT track

# Virtual environment folders
venv/
env/
.venv/
.env_dir/

# Secret environment variables — NEVER push your API key!
.env

# Python bytecode cache
__pycache__/
*.py[cod]
*$py.class

# macOS metadata
.DS_Store

# VS Code settings
.vscode/

# PyCharm / JetBrains IDE settings
.idea/

# Streamlit local config
.streamlit/secrets.toml

# Distribution / packaging artifacts
dist/
build/
*.egg-info/